.env
.env.local
.env.*.local
node_modules/
*.log
.DS_Store
/tmp/
output/
*.pdf
!examples/*.pdf

# User-supplied runtime configs (may contain client domains, API keys,
# narrative drafts). Example files (*.example.json, *.example.js) are
# checked in as templates; the unsuffixed real files must NEVER be.
audit-config.json
psi-config.json
channels.json
gsc-config.json
ai-citations-config.json

# Working data + cron history written by skills at runtime
data/
psi-history/
gsc-history/
ai-citations-history/
*.ndjson

# Private project material — never check in. Anything under these paths is
# user-local context (real client data, anonymized lesson drafts, exports).
# Privacy posture documented in ARCHITECTURE.md §5 (Privacy and client data).
private/
client-data/
real-data/
lessons/private/
case-notes/private/
local-notes/
tokens/
credentials/
exports/private/

# Per-user / per-repo profile + preferences (planned for v0.6+ adaptive onboarding).
# Schema documented in ARCHITECTURE.md §6 (planned); the local file must never be committed.
.growth-survival-kit/
.seo-survival-kit/

# Raw SEO data exports — SISTRIX, GSC, ranking trackers.
# Privacy posture in ARCHITECTURE.md §5; data contracts planned for later release.
sistrix-exports/
gsc-exports/
*_sistrix*.csv
*_visibility*.csv
*_keywords*.csv
*_ranking*.csv
