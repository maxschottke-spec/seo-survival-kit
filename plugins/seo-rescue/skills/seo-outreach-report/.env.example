# SEO-Outreach-Report — required credentials
#
# Copy this file to a private location (e.g. ~/.config/seo-outreach-report/.env)
# and fill in real values. NEVER commit the real .env to git.
#
# Run with: node --env-file=/path/to/your/.env script.js

# Sistrix API — for Visibility Index data
# Sign up: https://www.sistrix.de/
# API-Tier must allow at least `domain.sichtbarkeitsindex` endpoint.
SISTRIX_API_KEY=

# DataForSEO Labs — for live SERP rankings, backlinks, competitors
# Sign up: https://dataforseo.com/ (pay-per-call, ~1ct per call typical)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Google PageSpeed Insights v5 — for Performance + CrUX data
# Get key: https://console.cloud.google.com/
#   1. Create a GCP project
#   2. Enable "PageSpeed Insights API"
#   3. Create an API Key (restrict to that API)
GOOGLE_API_KEY=
