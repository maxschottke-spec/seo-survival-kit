{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "history.schema.json",
  "title": "Recovery Monitor History Entry",
  "description": "One line in history.ndjson. Each line is an independent JSON object.",
  "type": "object",
  "required": ["schema_version", "run_id", "data_quality", "confidence", "providers_used", "missing_capabilities", "status", "input_domain", "domain", "canonical_domain", "slug", "timestamp", "warnings", "errors", "score", "phase"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "run_id": { "type": "string", "pattern": "^\\d{8}-\\d{6}-[a-z0-9]+$" },
    "data_quality": { "type": "string", "enum": ["good", "partial", "poor"] },
    "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
    "providers_used": { "type": "array", "items": { "type": "string" } },
    "missing_capabilities": { "type": "array", "items": { "type": "string" } },
    "status": { "type": "string", "enum": ["complete", "partial", "failed"] },
    "input_domain": { "type": "string" },
    "domain": { "type": "string" },
    "canonical_domain": { "type": ["string", "null"] },
    "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{0,63}$" },
    "timestamp": { "type": "string", "format": "date-time" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } },
    "vi": { "type": ["number", "null"] },
    "vi_delta_pct": { "type": ["number", "null"] },
    "score": { "type": ["integer", "null"], "minimum": 0, "maximum": 100 },
    "phase": { "type": ["string", "null"], "enum": ["R1", "R2", "R3", "R4", "R5", null], "description": "null when no befund.json baseline exists or no score could be computed." },
    "keywords_t10": { "type": ["integer", "null"] },
    "keywords_t10_delta": { "type": ["integer", "null"] },
    "keywords_total": { "type": ["integer", "null"] },
    "top_losers_recovered": { "type": ["integer", "null"] },
    "issues_open": { "type": ["integer", "null"] },
    "issues_fixed": { "type": ["integer", "null"] },
    "issue_data_fresh": { "type": "boolean" },
    "source_notes": { "type": "array", "items": { "type": "string" } },
    "change_effects": {
      "type": ["array", "null"],
      "description": "Effect tracking per change from change-history.ndjson (read-only integration); null when no change history exists.",
      "items": { "type": "object" }
    },
    "audit_health": {
      "type": ["object", "null"],
      "description": "Audit-gap summary from the Change History Integration; null when no change history exists.",
      "properties": {
        "change_history_present": { "type": "boolean" },
        "total_tracked_changes_28d": { "type": ["integer", "null"] },
        "untracked_changes_detected": { "type": ["integer", "null"] },
        "anomalies_detected": { "type": ["integer", "null"] }
      }
    },
    "component_scores": {
      "type": "object",
      "description": "Per-component { value, weight } objects. Unavailable components are null. Weights are normalized over the available components and sum to 1.0.",
      "properties": {
        "vi_trend": { "$ref": "#/$defs/scoreComponent" },
        "keyword_stability": { "$ref": "#/$defs/scoreComponent" },
        "quick_win_progress": { "$ref": "#/$defs/scoreComponent" },
        "issue_reduction": { "$ref": "#/$defs/scoreComponent" },
        "backlink_quality": { "$ref": "#/$defs/scoreComponent" }
      }
    },
    "settlement_gate_status": {
      "type": "object",
      "description": "Settlement-Gate awareness mirror (read from recovery-gate.json, written by recovery-audit). active:false when no gate file exists.",
      "required": ["active"],
      "properties": {
        "active": { "type": "boolean" },
        "next_allowed_review_date": { "type": "string" },
        "unlock_status": { "type": "string", "enum": ["blocked", "partial", "open"] }
      }
    }
  },
  "$defs": {
    "scoreComponent": {
      "type": ["object", "null"],
      "required": ["value", "weight"],
      "properties": {
        "value": { "type": "number", "minimum": 0, "maximum": 100 },
        "weight": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }
      }
    }
  }
}
