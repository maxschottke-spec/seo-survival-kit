{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SEO Change Budget",
  "description": "Pre-execution change plan with risk budget tracking. v1.3.0 enforces (via if/then) the pre-check presence per change type, the section-7.C override requirements, and Reserve-bleibt-Reserve during an active Settlement Gate — previously these were documentation-only. v1.2.0 added Settlement Gate awareness on top of v1.1.0 Shopware/DreiscSeo pre-check requirements and DACH medical compliance.",
  "type": "object",
  "required": ["schema_version", "mode", "change_budget", "planned_changes", "total_risk_points", "budget_remaining", "stop_required"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.3.0" },
    "run_id": { "type": "string" },
    "domain": { "type": "string" },
    "mode": {
      "type": "string",
      "enum": ["audit_only", "micro_fix", "low_risk_fix", "controlled_recovery", "emergency_rollback", "high_risk_requires_approval"]
    },
    "change_budget": { "type": "integer", "minimum": 0 },
    "planned_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "change_category", "target", "description", "risk_points_base", "risk_points_final", "data_sources", "confidence"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["redirect", "category_status", "product_status", "cms_slot", "internal_link", "anchor_text", "plugin_config", "canonical", "h1", "template", "cache", "other"]
          },
          "change_category": {
            "type": "string",
            "enum": ["structural", "repair_hygiene", "emergency_stabilization"],
            "description": "Structural changes have 3-5 URL/day limits; repair_hygiene allows up to 10; emergency_stabilization up to 30 risk points"
          },
          "target": { "type": "string" },
          "description": { "type": "string" },
          "risk_points_base": { "type": "integer", "minimum": 0 },
          "multipliers": { "type": "array", "items": { "type": "string" } },
          "risk_points_final": { "type": "integer", "minimum": 0 },
          "data_sources": { "type": "array", "items": { "type": "string" } },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
          "rollback_method": { "type": "string" },
          "requires_explicit_approval": { "type": "boolean" },
          "requires_pre_check_for_duplicate_foreignkey_in_channel": {
            "type": "boolean",
            "description": "Mandatory true for all seo-url PATCH/POST operations"
          },
          "seo_url_precheck": {
            "type": "object",
            "properties": {
              "foreignKey": { "type": "string" },
              "routeName": { "type": "string" },
              "salesChannelId": { "type": "string" },
              "languageId": { "type": "string" },
              "active_non_deleted_entries": { "type": "integer" },
              "collision_detected": { "type": "boolean" }
            }
          },
          "requires_dreiscseo_redirect_precheck": {
            "type": "boolean",
            "description": "Mandatory true for category/product deactivations"
          },
          "dreiscseo_precheck": {
            "type": "object",
            "properties": {
              "redirects_from_url": { "type": "array" },
              "redirects_to_url": { "type": "array" },
              "would_create_301_to_404": { "type": "boolean" },
              "affected_redirect_ids": { "type": "array", "items": { "type": "string" } }
            }
          },
          "requires_cms_slot_snapshot": {
            "type": "boolean",
            "description": "Mandatory true for cms-slot PATCH operations"
          },
          "snapshot_paths": {
            "type": "object",
            "properties": {
              "before_path": { "type": "string" },
              "after_path": { "type": "string" }
            }
          },
          "pre_change_state_check": {
            "type": "object",
            "description": "Pre-change live state verification. Required for every change in a Settlement-Gate override; technical_emergency overrides require method live_http or live_http_and_api (API state alone is not sufficient per SEO_SETTLEMENT_GATE.md 7.A).",
            "required": ["method"],
            "properties": {
              "method": { "type": "string", "enum": ["live_http", "api_state", "live_http_and_api"] },
              "checked_at": { "type": "string" },
              "result": { "type": "string" }
            }
          },
          "hypothesis_id": {
            "type": "string",
            "description": "Reference into the hypothesis_registry of the recovery-audit output (HYPOTHESIS_VERIFICATION_GATE.md). Required for live-fix-eligible actions in recovery-plan Step 8a."
          },
          "hypothesis_status_snapshot": {
            "type": "string",
            "enum": ["suspected", "likely", "verified", "fixed"]
          },
          "fix_scope_match": { "type": "boolean" },
          "verified_by_source_tier": { "type": "string", "enum": ["strongest", "strong", "weak"] },
          "compliance_review": {
            "type": "string",
            "enum": ["none", "recommended", "required"]
          },
          "medical_terms_detected": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "term": { "type": "string" },
                "risk_tier": { "type": "string", "enum": ["high", "medium", "low"] },
                "target_substantiates": { "type": ["boolean", "string"] }
              }
            }
          }
        },
        "allOf": [
          {
            "if": { "properties": { "type": { "const": "redirect" } }, "required": ["type"] },
            "then": {
              "required": ["requires_pre_check_for_duplicate_foreignkey_in_channel", "seo_url_precheck"],
              "properties": {
                "requires_pre_check_for_duplicate_foreignkey_in_channel": { "const": true },
                "seo_url_precheck": { "required": ["foreignKey", "collision_detected"] }
              }
            }
          },
          {
            "if": { "properties": { "type": { "enum": ["category_status", "product_status"] } }, "required": ["type"] },
            "then": {
              "required": ["requires_dreiscseo_redirect_precheck", "dreiscseo_precheck"],
              "properties": {
                "requires_dreiscseo_redirect_precheck": { "const": true },
                "dreiscseo_precheck": { "required": ["would_create_301_to_404"] }
              }
            }
          },
          {
            "if": { "properties": { "type": { "const": "cms_slot" } }, "required": ["type"] },
            "then": {
              "required": ["requires_cms_slot_snapshot", "snapshot_paths"],
              "properties": {
                "requires_cms_slot_snapshot": { "const": true },
                "snapshot_paths": { "required": ["before_path"] }
              }
            }
          }
        ]
      }
    },
    "total_risk_points": { "type": "integer", "minimum": 0 },
    "budget_remaining": { "type": "integer" },
    "stop_required": { "type": "boolean" },
    "stop_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "examples": [
          "broad_batch_approval_invalid",
          "budget_exceeded",
          "more_than_5_urls_without_batch_plan",
          "more_than_3_links_per_blog_post",
          "shopware_seo_url_foreignkey_collision",
          "dreiscseo_precheck_missing",
          "dreiscseo_would_create_301_to_404",
          "cms_slot_snapshot_missing",
          "medical_term_high_risk_unsubstantiated",
          "live_test_404_after_change",
          "redirect_chain_to_404",
          "settlement_gate_active",
          "settlement_gate_override_not_approved",
          "unused_budget_is_not_permission"
        ]
      }
    },
    "settlement_gate_active": {
      "type": "boolean",
      "description": "True when a Settlement Gate is active for this domain. When true, only audit_only and emergency_rollback modes may be planned. See references/SEO_SETTLEMENT_GATE.md."
    },
    "settlement_gate_override_requested": {
      "type": "boolean",
      "description": "True when this Change Plan attempts to bypass an active Settlement Gate via section 7.C of SEO_SETTLEMENT_GATE.md."
    },
    "settlement_gate_override_allowed": {
      "type": "boolean",
      "description": "True when the override request meets section 7.C requirements: technical_emergency or rollback_stabilization or explicit_emergency_approval with all required fields present."
    },
    "override_reason": {
      "type": "string",
      "description": "Stated reason for the override request. Required when settlement_gate_override_requested is true."
    },
    "override_type": {
      "type": "string",
      "enum": ["technical_emergency", "rollback_stabilization", "explicit_emergency_approval"],
      "description": "Which exception class from SEO_SETTLEMENT_GATE.md section 7 the override falls under."
    },
    "unlock_status": {
      "type": "string",
      "enum": ["blocked", "partial", "open"],
      "description": "Mirror of recovery-gate.schema.json unlock_status at the time this plan was generated. blocked = plan must be audit_only or emergency_rollback only."
    },
    "unused_budget_handling": {
      "type": "string",
      "enum": ["forfeit", "carry_forward_after_unlock", "carry_forward_with_new_change_plan"],
      "default": "forfeit",
      "description": "Defines how unused points from this plan window are handled. Default and required during Settlement Gate: forfeit. Unused budget is never permission for additional work in the same window."
    },
    "reserve_bleibt_reserve_acknowledged": {
      "type": "boolean",
      "description": "Explicit acknowledgement that unused budget will not be spent without a new Change Plan and explicit approval. Must be true when a Settlement Gate is active."
    },
    "requires_explicit_approval": { "type": "boolean" },
    "approval_phrase_required": { "type": "boolean" },
    "approval_validation": {
      "type": "object",
      "properties": {
        "approval_text": { "type": "string" },
        "is_valid": { "type": "boolean" },
        "matched_elements": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["number", "type", "risk_points", "urls", "plan_reference", "permission"]
          }
        },
        "missing_elements": { "type": "array", "items": { "type": "string" } },
        "reason": { "type": "string" }
      }
    },
    "post_change_checks": { "type": "array", "items": { "type": "string" } },
    "hypothesis_verification_gate": {
      "type": "object",
      "description": "Result of the Hypothesis Verification Gate (recovery-plan Step 8a / lib/safe.js checkHypothesisScopeMatch). audit_output_available=false means no recovery-audit output existed — plan is roadmap-only, not an error.",
      "properties": {
        "audit_output_available": { "type": "boolean" },
        "all_planned_changes_verified": { "type": "boolean" },
        "below_verified_count": { "type": "integer", "minimum": 0 },
        "scope_expansions_blocked": { "type": "array", "items": { "type": "string" } },
        "missing_hypothesis_ids": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "settlement_gate_override_requested": { "const": true } }, "required": ["settlement_gate_override_requested"] },
      "then": { "required": ["override_reason", "override_type"] }
    },
    {
      "if": { "properties": { "override_type": { "const": "explicit_emergency_approval" } }, "required": ["override_type"] },
      "then": {
        "required": ["override_reason", "total_risk_points", "approval_validation", "post_change_checks"],
        "properties": {
          "post_change_checks": { "minItems": 1 },
          "approval_validation": { "required": ["approval_text", "is_valid"] },
          "planned_changes": {
            "minItems": 1,
            "items": {
              "required": ["rollback_method", "pre_change_state_check"],
              "properties": { "confidence": { "enum": ["high", "medium"] } }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "override_type": { "const": "technical_emergency" } }, "required": ["override_type"] },
      "then": {
        "properties": {
          "planned_changes": {
            "items": {
              "required": ["pre_change_state_check"],
              "properties": {
                "pre_change_state_check": {
                  "properties": { "method": { "enum": ["live_http", "live_http_and_api"] } }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "settlement_gate_active": { "const": true } }, "required": ["settlement_gate_active"] },
      "then": {
        "required": ["reserve_bleibt_reserve_acknowledged"],
        "properties": {
          "reserve_bleibt_reserve_acknowledged": { "const": true },
          "unused_budget_handling": { "const": "forfeit" }
        }
      }
    }
  ]
}
