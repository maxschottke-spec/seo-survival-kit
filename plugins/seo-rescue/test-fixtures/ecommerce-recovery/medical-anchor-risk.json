  "multiplier_rules": {
    "high_risk_term_in_change": "x2 risk points + compliance_review: required + block if introducing new",
    "medium_risk_term_in_change": "x2 risk points + compliance_review: required + verify target substantiates",
    "low_risk_term": "no multiplier + no compliance review"
