    },
    {
      "anchor": "Orthopaedische Matratze (as product category name)",
      "context": "Shopware category name in navigation",
      "expected_risk_tier": "medium",
      "expected_compliance_review": "required",
      "expected_action": "Verify target page uses factual framing, not medical effect claims"
    },
    {
